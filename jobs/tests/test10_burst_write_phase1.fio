[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=900
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test10-burst-write-phase1]
rw=randrw
rwmixread=70
bs=256k
# Strict Rate Limiter (Total 3GB/s = ~375m per thread, 70/30 split)
rate=262m,113m
