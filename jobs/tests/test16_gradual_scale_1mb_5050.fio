[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=1800
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test16-scale-1m-5050]
rw=randrw
rwmixread=50
bs=1m
# 2,500 IOPS per pod / 8 threads = ~312 IOPS per thread
rate_iops=312
