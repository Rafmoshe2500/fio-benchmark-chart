[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=600
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test1-30k-5050-4k]
rw=randrw
rwmixread=50
bs=4k
# 10 pods * 3000 = 30K total IOPS. Since numjobs=8, rate_iops is per job or total for the block?
# In group reporting with numjobs, rate_iops is per-job. We want 3000 total across 8 jobs.
# 3000 / 8 = 375 IOPS per thread (approx)
rate_iops=375
