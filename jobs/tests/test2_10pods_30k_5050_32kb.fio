[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=600
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data

iodepth=32
iodepth_batch_submit=32
iodepth_batch_complete_min=1
iodepth_batch_complete_max=32

refill_buffers=0
scramble_buffers=0
randrepeat=0
norandommap=1
cpus_allowed_policy=split

[test2-30k-32k-write-1]
rw=randwrite
bs=32k
rate_iops=1875

[test2-30k-32k-read-1]
rw=randread
bs=32k
rate_iops=1750

[test2-30k-32k-write-2]
rw=randwrite
bs=32k
rate_iops=1875

[test2-30k-32k-read-2]
rw=randread
bs=32k
rate_iops=1750

[test2-30k-32k-write-3]
rw=randwrite
bs=32k
rate_iops=1875

[test2-30k-32k-read-3]
rw=randread
bs=32k
rate_iops=1750

[test2-30k-32k-write-4]
rw=randwrite
bs=32k
rate_iops=1875

[test2-30k-32k-read-4]
rw=randread
bs=32k
rate_iops=1750
