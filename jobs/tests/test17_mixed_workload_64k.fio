[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=900
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test17-mixed-64k]
rw=randrw
rwmixread=50
bs=64k
# 2,000 IOPS per pod / 8 threads = 250 IOPS per thread
rate_iops=250
