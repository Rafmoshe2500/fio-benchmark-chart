[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=600
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=64

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test4-50k-32k-write-1]
rw=randwrite
bs=32k
rate_iops=2500

[test4-50k-32k-read-1]
rw=randread
bs=32k
rate_iops=2500

[test4-50k-32k-write-2]
rw=randwrite
bs=32k
rate_iops=2500

[test4-50k-32k-read-2]
rw=randread
bs=32k
rate_iops=2500

[test4-50k-32k-write-3]
rw=randwrite
bs=32k
rate_iops=2500

[test4-50k-32k-read-3]
rw=randread
bs=32k
rate_iops=2500

[test4-50k-32k-write-3]
rw=randwrite
bs=32k
rate_iops=2500

[test4-50k-32k-read-4]
rw=randread
bs=32k
rate_iops=2500
