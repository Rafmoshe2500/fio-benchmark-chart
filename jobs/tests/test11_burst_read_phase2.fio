[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=90
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=4

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test11-burst-read-phase2]
rw=randread
bs=512k
# 10,000 MB/s per pod / 8 threads = 1250m per thread
rate=1250m
