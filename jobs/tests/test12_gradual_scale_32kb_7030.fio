[global]
ioengine=libaio
direct=1
size=1G
runtime=1800
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test12-scale-32k-75-read-1]
rw=randread
bs=32k
rate_iops=1500

[test12-scale-32k-25-write-1]
rw=randrw
bs=32k
rate_iops=500

[test12-scale-32k-75-read-2]
rw=randread
bs=32k
rate_iops=1500

[test12-scale-32k-25-write-2]
rw=randrw
bs=32k
rate_iops=500

[test12-scale-32k-75-read-3]
rw=randread
bs=32k
rate_iops=1500

[test12-scale-32k-25-write-3]
rw=randrw
bs=32k
rate_iops=500

[test12-scale-32k-75-read-4]
rw=randread
bs=32k
rate_iops=1500

[test12-scale-32k-25-write-4]
rw=randrw
bs=32k
rate_iops=500
