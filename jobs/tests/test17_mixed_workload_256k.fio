[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=900
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
iodepth=16
refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test17-mixed-256k-job1]
rw=randrw
bs=256k
rwmixread=10
rate_iops=250

[test17-mixed-256k-job2]
rw=randrw
bs=256k
rwmixread=25
rate_iops=250

[test17-mixed-256k-job3]
rw=randrw
bs=256k
rwmixread=40
rate_iops=250

[test17-mixed-256k-job4]
rw=randrw
bs=256k
rwmixread=55
rate_iops=250

[test17-mixed-256k-job5]
rw=randrw
bs=256k
rwmixread=70
rate_iops=250

[test17-mixed-256k-job6]
rw=randrw
bs=256k
rwmixread=85
rate_iops=250

[test17-mixed-256k-job7]
rw=randrw
bs=256k
rwmixread=95
rate_iops=250

[test17-mixed-256k-job8]
rw=randrw
bs=256k
rwmixread=5
rate_iops=250
