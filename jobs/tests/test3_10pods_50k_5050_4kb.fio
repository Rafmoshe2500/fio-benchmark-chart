[global]
ioengine=libaio
direct=1
fallocate=none
size=10G
runtime=600
ramp_time=60
time_based=1
group_reporting=1
directory=/mnt/fio-data
numjobs=8
iodepth=16

refill_buffers=1
scramble_buffers=1
randrepeat=0
norandommap=1

[test3-50k-5050-4k]
rw=randrw
rwmixread=50
bs=4k
# Target 5000 IOPS per pod. 5000 / 8 jobs = 625 IOPS per thread
rate_iops=625
